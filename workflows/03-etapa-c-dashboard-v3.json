    {
      "parameters": {
        "jsCode": "// Alerta liviana de portafolio - no decide nada, solo avisa antigüedad para que el\n// abogado Senior priorice la revisión manual (Etapa C sigue siendo 100% humana).\n// v3.1: ignora filas vacías y fechas inválidas.\nconst UMBRAL_DIAS_EN_DECISION = 10;\nconst casos = $input.all().map(x => x.json).filter(c => c.caso_id);\nconst ahora = Date.now();\n\nconst estancados = casos.filter(c => {\n  if (c.estado !== 'En decisión') return false;\n  const t = new Date(c.fecha_captura).getTime();\n  if (isNaN(t)) return false;  // fecha inválida o vacía: no rompe el cálculo\n  return (ahora - t) / (1000 * 60 * 60 * 24) > UMBRAL_DIAS_EN_DECISION;\n});\n\nreturn [{ json: { hay_estancados: estancados.length > 0, cantidad: estancados.length,\n                   casos: estancados.map(c => c.caso_id).join(', ') } }];\n"
      },
