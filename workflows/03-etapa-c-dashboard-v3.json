    {
      "parameters": {
        "jsCode": "// Sin IA ni decisiones automáticas: solo agrega lo que ya produjo la Etapa B (sección 5).\n// v3.1: corre en cadena (Casos -> Oficios -> acá) para no ejecutarse dos veces ni referenciar\n// nodos sin ejecutar; ignora filas vacías (alwaysOutputData) y agrega una fila TOTAL.\nconst casos = $('Leer Casos').all().map(x => x.json).filter(c => c.caso_id);\nconst oficios = $('Leer Oficios').all().map(x => x.json).filter(o => o.oficio_id || o.caso_id);\n\nconst PENDIENTES = ['Enviado', 'Reiterado 1', 'Reiterado 2'];\nconst RESPONDIDOS = ['Respondida', 'Respondida parcial', 'Rechazo solicitud'];\n\nconst estadoPorCaso = {};\nconst porEstado = {};\nfor (const c of casos) {\n  const e = c.estado || '(sin estado)';\n  estadoPorCaso[c.caso_id] = e;\n  porEstado[e] = (porEstado[e] || 0) + 1;\n}\n\nconst totalOficios = oficios.length;\nconst totalRespondidos = oficios.filter(o => RESPONDIDOS.includes(o.estado)).length;\nconst totalVencidos = oficios.filter(o => o.estado === 'Vencido sin respuesta').length;\nconst totalPendientes = oficios.filter(o => PENDIENTES.includes(o.estado)).length;\nconst pctGlobal = totalOficios ? Math.round((totalRespondidos / totalOficios) * 100) : 0;\nconst actualizado_el = new Date().toISOString();\n\nconst filas = Object.keys(porEstado).map(estado => ({\n  estado,\n  cantidad_casos: porEstado[estado],\n  oficios_pendientes: oficios.filter(o => estadoPorCaso[o.caso_id] === estado && PENDIENTES.includes(o.estado)).length,\n  oficios_vencidos: oficios.filter(o => estadoPorCaso[o.caso_id] === estado && o.estado === 'Vencido sin respuesta').length,\n  pct_respondidos_global: pctGlobal,\n  actualizado_el,\n}));\n\n// fila resumen del portafolio completo\nfilas.push({\n  estado: 'TOTAL (portafolio)',\n  cantidad_casos: casos.length,\n  oficios_pendientes: totalPendientes,\n  oficios_vencidos: totalVencidos,\n  pct_respondidos_global: pctGlobal,\n  actualizado_el,\n});\n\nreturn filas.map(f => ({ json: f }));\n"
      },
